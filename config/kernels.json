{
  "kernels": {
    "softmax-cuda": {
      "source_dir": "vendor/HeCBench/src/softmax-cuda",
      "build_command": [
        "make"
      ],
      "clean_command": [
        "make",
        "clean"
      ],
      "binary": "./main",
      "run_args": [
        "600000",
        "784",
        "1",
        "30"
      ],
      "timing": {
        "regex": "Average kernel execution time:\\s*([0-9.]+)\\s*\\(ms\\)",
        "unit": "ms"
      },
      "correctness": {
        "method": "pass_token",
        "pass_token": "PASS",
        "relative_tolerance": 0.0001,
        "absolute_tolerance": 1e-06
      },
      "allowed_files": [
        "main.cu"
      ],
      "notes": [
        "Makefile naive command with implementation 0 failed correctness on RTX 3080 Ti.",
        "Use implementation 1 as the softmax experiment target.",
        "Problem size increased to 600000 slices to exceed 5 ms."
      ]
    },
